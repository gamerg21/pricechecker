# Admin authentication (required to access /admin/* routes)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Optional: protect sync endpoint. If set, Celigo (or any client) must send:
#   Header: x-sync-key: <same value>
SYNC_API_KEY=

# Optional: override default SQLite path (default: ./data/price-checker.db)
# SQLITE_PATH=/path/to/price-checker.db
