# Admin authentication (required to access /admin/* routes)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Required when reverse-proxied without a single canonical URL.
# Set to true so NextAuth derives callback URLs from the request Host header
# instead of a hardcoded AUTH_URL. Lets you access /admin via IP, hostname,
# or any internal alias without breaking the login redirect.
AUTH_TRUST_HOST=true

# Optional: protect sync endpoint. If set, Celigo (or any client) must send:
#   Header: x-sync-key: <same value>
SYNC_API_KEY=

# Optional: override default SQLite path (default: ./data/price-checker.db)
# SQLITE_PATH=/path/to/price-checker.db
